# Copy to .env.local and fill in values. Names only here — never commit secrets.

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# CLERK_WEBHOOK_SECRET=

# Clerk redirect URLs (FALLBACK family; post-auth lands on /dashboard dispatcher)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=

# Twilio (SMS + Voice)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# WhatsApp sandbox (Part 2)
# Shared Twilio sandbox sender — store WITHOUT the "whatsapp:" prefix.
TWILIO_WHATSAPP_SANDBOX_NUMBER=
# UUID of the test business used for sandbox WhatsApp inbound.
WHATSAPP_SANDBOX_BUSINESS_ID=

# Site / misc
NEXT_PUBLIC_SITE_URL=
# Kill-switch: auto-provision a business+owner on signup with no users row.
SELF_SIGNUP_ENABLED=false
